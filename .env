# REQUIRED: Copy this file to .env.local and set your actual values
# These environment variables are REQUIRED for the app to work

# Parse backend configuration (required)
VUE_APP_PARSE_APP_ID=your_parse_app_id_here
VUE_APP_PARSE_JS_KEY=your_parse_js_key_here
VUE_APP_PARSE_SERVER_URL=https://parseapi.back4app.com/

# Imgur configuration (required)
VUE_APP_IMGUR_ID=your_imgur_client_id_here

# Mapbox token (required - keep secret)
VUE_APP_MAPBOX_TOKEN=your_mapbox_token_here
